---
import { ArrowRight, ArrowUpRight } from 'lucide-react';
import BrandLogo from '../components/BrandLogo.astro';
import HeroScene from '../components/HeroScene.astro';
import ServicesScene from '../components/ServicesScene.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const pillars = [
	{
		number: '01',
		title: 'Posicionamiento',
		text: 'Una identidad clara que destaque sin perder autenticidad.',
	},
	{
		number: '02',
		title: 'Monetizacion',
		text: 'Oferta, chatting y retencion conectados a objetivos reales.',
	},
	{
		number: '03',
		title: 'Escalado',
		text: 'Contenido, distribucion y decisiones guiadas por datos.',
	},
];

const services = [
	{
		number: '01',
		title: 'Marketing en redes sociales',
		text: 'Estrategias de contenido que conectan, convierten y construyen audiencia.',
	},
	{
		number: '02',
		title: 'Optimizacion de estrategia',
		text: 'Ajustamos, probamos y escalamos lo que funciona para tu marca.',
	},
	{
		number: '03',
		title: 'Desarrollo de branding',
		text: 'Identidad visual y posicionamiento para diferenciarte con criterio.',
	},
	{
		number: '04',
		title: 'Escalado y viralidad',
		text: 'Multiplicamos tu alcance con sistemas de distribucion medibles.',
	},
	{
		number: '05',
		title: 'Chatting en OnlyFans',
		text: 'Maximizamos conversion y retencion con interaccion estrategica.',
	},
	{
		number: '06',
		title: 'Management integral',
		text: 'Gestion completa para que puedas enfocarte en crear y liderar.',
	},
];

const process = [
	{
		number: '01',
		title: 'Auditoria',
		text: 'Analizamos tu presencia actual y detectamos oportunidades reales de crecimiento.',
	},
	{
		number: '02',
		title: 'Estrategia',
		text: 'Disenamos un plan alineado a tus objetivos, tu audiencia y tu posicionamiento.',
	},
	{
		number: '03',
		title: 'Ejecucion',
		text: 'Activamos contenido, chatting, optimizacion y reporting de forma coordinada.',
	},
	{
		number: '04',
		title: 'Escalado',
		text: 'Medimos, optimizamos y multiplicamos lo que funciona para tu marca.',
	},
];
---

<BaseLayout
	title="BON Management | Estrategia y crecimiento para creadoras"
	description="Marketing, branding, chatting y management para creadoras que quieren convertir su audiencia en un negocio escalable."
>
	<header class="fixed inset-x-0 top-0 z-50 border-b border-black/8 bg-white/92 backdrop-blur-xl">
		<div class="mx-auto flex h-20 max-w-[90rem] items-center justify-between px-5 sm:px-8 lg:px-12">
			<a class="focus-ring shrink-0" href="#inicio" aria-label="BON Management, inicio">
				<BrandLogo width="12rem" />
			</a>

			<nav class="hidden items-center gap-10 text-sm font-medium text-bon-ink md:flex" aria-label="Principal">
				<a class="transition-colors hover:text-bon-rose" href="#servicios">Servicios</a>
				<a class="transition-colors hover:text-bon-rose" href="#sistema">Sistema</a>
				<a class="transition-colors hover:text-bon-rose" href="#proceso">Proceso</a>
			</nav>

			<a
				class="focus-ring inline-flex min-h-11 items-center justify-center gap-2 rounded-[4px] bg-bon-black px-5 text-sm font-semibold text-white transition-colors hover:bg-bon-rose"
				href="#aplicar"
			>
				Aplicar
				<ArrowUpRight size={16} strokeWidth={1.8} aria-hidden="true" />
			</a>
		</div>
	</header>

	<main>
		<section id="inicio" class="relative overflow-hidden pt-20">
			<div class="absolute left-0 top-20 h-44 w-3 bg-bon-pink sm:w-5" aria-hidden="true"></div>
			<div class="mx-auto grid min-h-[82svh] max-w-[90rem] items-center px-5 py-12 sm:px-8 lg:grid-cols-2 lg:px-12 lg:py-8">
				<div class="relative z-10 max-w-2xl py-8 lg:translate-y-5" data-reveal>
					<h1 class="text-balance text-5xl font-medium leading-[1.02] text-bon-black sm:text-6xl lg:text-7xl">
						Tu marca.<br />Tu crecimiento.<br />Nuestro sistema.
					</h1>
					<p class="mt-7 max-w-xl text-lg leading-8 text-bon-muted sm:text-xl">
						Marketing, branding, chatting y management para creadoras que quieren convertir su audiencia en un negocio escalable.
					</p>
					<div class="mt-9 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
						<a
							class="focus-ring inline-flex min-h-13 items-center justify-center gap-3 rounded-[4px] bg-bon-black px-6 text-sm font-semibold text-white transition-colors hover:bg-bon-rose"
							href="#aplicar"
						>
							Solicitar auditoria
							<ArrowRight size={17} strokeWidth={1.8} aria-hidden="true" />
						</a>
						<a class="focus-ring border-b border-bon-black pb-1 text-sm font-semibold transition-colors hover:border-bon-rose hover:text-bon-rose" href="#sistema">
							Descubrir el sistema
						</a>
					</div>
				</div>

				<div class="relative min-h-[20rem] lg:h-[calc(82svh-5rem)] lg:min-h-[38rem]" data-reveal>
					<HeroScene />
				</div>
			</div>
		</section>

		<section id="sistema" class="relative">
			<div class="bg-bon-blush">
				<div class="mx-auto grid max-w-[90rem] gap-8 px-5 py-16 sm:px-8 lg:grid-cols-[12rem_1fr] lg:px-12 lg:py-20">
					<div class="hidden border-l-[4rem] border-bon-pink/55 lg:block" aria-hidden="true"></div>
					<div class="max-w-4xl" data-reveal>
						<h2 class="text-balance text-4xl font-medium leading-tight text-bon-black sm:text-5xl lg:text-6xl">No trabajamos para todas.</h2>
						<p class="mt-5 max-w-2xl text-lg leading-8 text-bon-muted sm:text-xl">
							Trabajamos con creadoras que quieren construir una marca rentable, sostenible y con direccion.
						</p>
					</div>
				</div>
			</div>

			<div class="relative overflow-hidden bg-white">
				<div class="mx-auto grid max-w-[90rem] gap-12 px-5 pb-32 pt-20 sm:px-8 md:grid-cols-3 lg:px-12 lg:pb-40">
					{pillars.map((pillar) => (
						<article class="relative z-10 max-w-sm" data-reveal>
							<p class="text-2xl font-medium text-bon-pink">{pillar.number}</p>
							<h3 class="mt-4 text-2xl font-medium text-bon-black sm:text-3xl">{pillar.title}</h3>
							<p class="mt-4 text-base leading-7 text-bon-muted">{pillar.text}</p>
						</article>
					))}
				</div>

				<svg class="pointer-events-none absolute inset-x-0 bottom-4 h-32 w-full sm:h-44" viewBox="0 0 1440 180" preserveAspectRatio="none" aria-hidden="true">
					<path d="M-40 112 C 130 205, 270 22, 470 112 S 820 202, 1010 101 S 1280 20, 1490 112" fill="none" stroke="#0b0b0d" stroke-width="28" stroke-linecap="round" />
					<rect x="365" y="35" width="120" height="128" rx="6" fill="#edcbd3" fill-opacity="0.34" stroke="#d894a3" stroke-opacity="0.7" stroke-width="3" />
					<rect x="920" y="28" width="120" height="128" rx="6" fill="#edcbd3" fill-opacity="0.34" stroke="#d894a3" stroke-opacity="0.7" stroke-width="3" />
				</svg>
			</div>
		</section>

		<section id="servicios" class="relative border-t border-bon-line bg-white">
			<div class="mx-auto max-w-[90rem] px-5 py-24 sm:px-8 lg:px-12 lg:py-32">
				<div class="grid gap-8 lg:grid-cols-[7rem_1fr]">
					<div class="hidden h-48 w-10 bg-bon-pink/55 lg:block" aria-hidden="true"></div>
					<div data-reveal>
						<p class="text-sm font-semibold text-bon-rose">Servicios</p>
						<div class="mt-5 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
							<h2 class="max-w-3xl text-balance text-4xl font-medium leading-tight text-bon-black sm:text-5xl">
								Un sistema completo para creadoras que lideran.
							</h2>
							<p class="max-w-xl text-lg leading-8 text-bon-muted">
								Acompanamos cada etapa de tu marca con estrategia, estructura y ejecucion alineadas a tus objetivos.
							</p>
						</div>
					</div>
				</div>

				<div class="mt-16 grid items-center gap-x-10 lg:grid-cols-[1fr_24rem_1fr]">
					<div>
					{services.slice(0, 3).map((service) => (
						<a class="group grid grid-cols-[2.5rem_1fr_auto] gap-4 border-b border-bon-line py-7" href="#aplicar" data-reveal>
							<span class="text-base font-medium text-bon-pink">{service.number}</span>
							<span>
								<strong class="block text-xl font-medium text-bon-black transition-colors group-hover:text-bon-rose sm:text-2xl">{service.title}</strong>
								<span class="mt-2 block max-w-lg text-sm leading-6 text-bon-muted">{service.text}</span>
							</span>
							<ArrowUpRight className="mt-1 transition-transform group-hover:-translate-y-1 group-hover:translate-x-1" size={21} strokeWidth={1.5} aria-hidden="true" />
						</a>
					))}
					</div>
					<ServicesScene />
					<div>
					{services.slice(3).map((service) => (
						<a class="group grid grid-cols-[2.5rem_1fr_auto] gap-4 border-b border-bon-line py-7" href="#aplicar" data-reveal>
							<span class="text-base font-medium text-bon-pink">{service.number}</span>
							<span>
								<strong class="block text-xl font-medium text-bon-black transition-colors group-hover:text-bon-rose sm:text-2xl">{service.title}</strong>
								<span class="mt-2 block max-w-lg text-sm leading-6 text-bon-muted">{service.text}</span>
							</span>
							<ArrowUpRight className="mt-1 transition-transform group-hover:-translate-y-1 group-hover:translate-x-1" size={21} strokeWidth={1.5} aria-hidden="true" />
						</a>
					))}
					</div>
				</div>
			</div>
		</section>

		<section id="proceso" class="relative overflow-hidden border-t border-bon-line bg-white">
			<div class="mx-auto max-w-[90rem] px-5 py-24 sm:px-8 lg:px-12 lg:py-32">
				<div class="max-w-4xl" data-reveal>
					<p class="text-sm font-semibold text-bon-rose">Proceso</p>
					<h2 class="mt-5 text-balance text-4xl font-medium leading-tight text-bon-black sm:text-5xl">Un proceso claro. Un equipo detras.</h2>
					<p class="mt-5 max-w-2xl text-lg leading-8 text-bon-muted">Metodologia simple, comunicacion constante y acciones alineadas a tus objetivos.</p>
				</div>

				<div class="relative mt-16 grid gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
					<div class="absolute left-0 right-0 top-[3.25rem] hidden h-px bg-bon-pink/75 lg:block" aria-hidden="true"></div>
					{process.map((step) => (
						<article class="relative" data-reveal>
							<p class="text-xl font-medium text-bon-pink">{step.number}</p>
							<span class="mt-8 hidden h-3 w-3 bg-bon-pink lg:block" aria-hidden="true"></span>
							<h3 class="mt-6 text-2xl font-medium text-bon-black">{step.title}</h3>
							<p class="mt-4 text-sm leading-6 text-bon-muted">{step.text}</p>
						</article>
					))}
				</div>
			</div>

			<div class="relative h-28" aria-hidden="true">
				<div class="absolute left-[-5%] right-[-5%] top-10 h-7 rotate-2 rounded-full bg-bon-black shadow-[0_12px_26px_rgba(11,11,13,0.18)]"></div>
				<div class="absolute left-1/2 top-0 h-28 w-28 -translate-x-1/2 rounded-[8px] border-4 border-bon-pink/65 bg-bon-blush/55 shadow-[0_18px_40px_rgba(184,111,128,0.18)]"></div>
			</div>
		</section>

		<section id="aplicar" class="grid bg-bon-blush lg:grid-cols-[1fr_21rem]">
			<div class="px-5 py-20 sm:px-8 lg:px-12 lg:py-24">
				<div class="mx-auto max-w-[69rem]" data-reveal>
					<h2 class="max-w-3xl text-balance text-4xl font-medium leading-tight text-bon-black sm:text-5xl lg:text-6xl">Tu contenido ya tiene valor. Hagamos que crezca.</h2>
					<p class="mt-5 max-w-xl text-lg leading-8 text-bon-muted">Solicita una auditoria y descubre que necesita tu marca para dar el siguiente paso.</p>
					<a class="focus-ring mt-8 inline-flex min-h-13 items-center justify-center gap-3 rounded-[4px] bg-bon-black px-6 text-sm font-semibold text-white transition-colors hover:bg-bon-rose" href="mailto:hello@bonmanagement.com">
						Aplicar ahora
						<ArrowUpRight size={17} strokeWidth={1.8} aria-hidden="true" />
					</a>
				</div>
			</div>
			<div class="flex min-h-72 items-center justify-center bg-bon-black px-8 py-16">
				<BrandLogo variant="white" width="15rem" />
			</div>
		</section>
	</main>

	<footer class="border-t border-bon-line bg-white">
		<div class="mx-auto flex max-w-[90rem] flex-col gap-6 px-5 py-8 text-sm text-bon-muted sm:px-8 md:flex-row md:items-center md:justify-between lg:px-12">
			<BrandLogo width="10.5rem" />
			<div class="flex flex-wrap items-center gap-x-8 gap-y-3">
				<a class="hover:text-bon-rose" href="#">Instagram</a>
				<a class="hover:text-bon-rose" href="#">Privacidad</a>
				<a class="hover:text-bon-rose" href="mailto:hello@bonmanagement.com">Contacto</a>
				<span>2026</span>
			</div>
		</div>
	</footer>

	<script>
		import { gsap } from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';

		gsap.registerPlugin(ScrollTrigger);

		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const initRevealAnimations = () => {
			if (reduceMotion) return;

			gsap.utils.toArray('[data-reveal]').forEach((element) => {
				gsap.fromTo(
					element,
					{ autoAlpha: 0, y: 28 },
					{
						autoAlpha: 1,
						duration: 0.85,
						ease: 'power3.out',
						y: 0,
						scrollTrigger: {
							trigger: element,
							start: 'top 88%',
							once: true,
						},
					},
				);
			});

			ScrollTrigger.refresh();
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initRevealAnimations, { once: true });
		} else {
			initRevealAnimations();
		}
	</script>
</BaseLayout>
